# top-most EditorConfig file
root = true

# Default settings for all files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
# trim_trailing_whitespace = true
insert_final_newline = true

# Markdown-specific overrides
[*.md]
indent_size = 2
trim_trailing_whitespace = false  # allows trailing spaces for line breaks. Currently doesn't work when set to true for all files.
